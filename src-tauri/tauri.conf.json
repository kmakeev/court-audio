{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Аудиопротокол",
  "version": "0.2.0",
  "identifier": "ru.court.audioprotocol",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Аудиопротокол",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "nsis", "dmg"],
    "publisher": "Аудиопротокол",
    "copyright": "© 2026 Аудиопротокол. Правообладатель уточняется (этап 08).",
    "category": "Utility",
    "shortDescription": "Аудиопротоколирование судебных заседаний",
    "longDescription": "Надёжная запись звука в зале суда с привязкой к делу и выгрузкой в экспертную систему. Только аудио (v1).",
    "homepage": "https://court.local/audioprotocol",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2",
          "libasound2",
          "libssl3"
        ]
      },
      "rpm": {
        "release": "1",
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libayatana-appindicator-gtk3",
          "librsvg2",
          "alsa-lib",
          "openssl-libs"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "webview2/"
      },
      "digestAlgorithm": "sha256",
      "nsis": {
        "languages": ["Russian"],
        "installMode": "both",
        "displayLanguageSelector": false
      }
    }
  }
}
