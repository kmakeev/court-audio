<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements macOS-бандла (подключены через bundle.macOS.entitlements в
  tauri.conf.json). Для подписанного/hardened-рантайма доступ к микрофону
  требует явного com.apple.security.device.audio-input. Подпись — этап 08
  (docs/packaging.md); macOS — dev-таргет.
-->
<plist version="1.0">
  <dict>
    <key>com.apple.security.device.audio-input</key>
    <true/>
  </dict>
</plist>
